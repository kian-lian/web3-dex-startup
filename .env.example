# =============================================================================
# Environment Variables Reference
#
# Copy this file to .env.local and fill in your secrets.
# See src/shared/config/env.ts for how these are consumed.
#
# Files loaded by Next.js (in order):
#   .env                  — shared defaults (committed)
#   .env.development      — dev overrides (committed)
#   .env.production       — production overrides (committed)
#   .env.test             — test overrides (committed)
#   .env.local            — local secret overrides (gitignored)
# =============================================================================

# ---------------------------------------------------------------------------
# Required (production build will fail without these)
# ---------------------------------------------------------------------------

# WalletConnect Cloud project ID — get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---------------------------------------------------------------------------
# Optional — app settings (defaults shown)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="Web3 DEX"
NEXT_PUBLIC_ENABLE_TESTNETS=false
NEXT_PUBLIC_DEFAULT_CHAIN_ID=1

# ---------------------------------------------------------------------------
# Sentry — observability (DSN is a public client key, not a secret)
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=0
