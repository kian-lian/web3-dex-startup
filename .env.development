# Development overrides — loaded by `pnpm dev`

# Enable testnets for development (Sepolia, Arbitrum Sepolia)
NEXT_PUBLIC_ENABLE_TESTNETS=true
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# Sentry — disable or minimal sampling in dev
