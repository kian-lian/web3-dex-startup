NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=0


NEXT_PUBLIC_APP_NAME="Web3 DEX"

