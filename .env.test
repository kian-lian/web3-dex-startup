# Test overrides — loaded by vitest (NODE_ENV=test)
# Note: .env.local is NOT loaded in test environment (by Next.js design)

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=test-project-id

NEXT_PUBLIC_ENABLE_TESTNETS=true
NEXT_PUBLIC_DEFAULT_CHAIN_ID=31337

NEXT_PUBLIC_SENTRY_ENVIRONMENT=test
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=0
