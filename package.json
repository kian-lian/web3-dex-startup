{
  "name": "web3-cex-startup",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write",
    "spellcheck": "cspell \"src/**/*.{ts,tsx}\" --no-progress",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:run && cross-env NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=test-project-id pnpm build && pnpm spellcheck",
    "security:audit": "pnpm audit --audit-level=high",
    "security:secrets": "gitleaks detect --source . --no-banner",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@sentry/nextjs": "^10.42.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.0-canary.91",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.47.0",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@next/bundle-analyzer": "^15.3.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^7.0.3",
    "cspell": "^9.7.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "pino-pretty": "^13.1.3",
    "shadcn": "^4.0.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{js,ts,jsx,tsx}": [
      "cspell --no-must-find-files --no-progress",
      "node scripts/check-file-header.js"
    ]
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
