# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — only ignore local overrides (which contain real secrets)
# .env, .env.development, .env.test, .env.production are committed (non-secret defaults)
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code - local overrides (personal, not shared)
.claude/settings.local.json

# Sentry Config File
.env.sentry-build-plugin
